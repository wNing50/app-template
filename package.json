{
  "name": "app-template",
  "private": true,
  "scripts": {
    "android": "npm --prefix app run android",
    "android:dev": "npm --prefix app run android:dev",
    "android:cloud": "npm --prefix app run android:cloud",
    "server": "npm --prefix server run start",
    "server:dev": "npm --prefix server run start:dev",
    "server:cloud": "npm --prefix server run start:cloud",
    "web": "npm --prefix web run dev",
    "web:dev": "npm --prefix web run dev:dev",
    "web:cloud": "npm --prefix web run dev:cloud",
    "admin": "npm --prefix admin run dev",
    "admin:dev": "npm --prefix admin run dev:dev",
    "admin:cloud": "npm --prefix admin run dev:cloud",
    "test:app": "npm --prefix app test",
    "test:app:typecheck": "npm --prefix app run typecheck",
    "test:server": "npm --prefix server test",
    "test:scripts": "node --test scripts/*.test.js",
    "test": "npm run test:app && npm run test:server && npm run test:app:typecheck && npm run test:scripts",
    "version:app": "node scripts/bump-app-version.js",
    "docker:down:dev": "node scripts/docker-server.js down dev",
    "docker:up:dev": "node scripts/docker-server.js up dev",
    "docker:redeploy:dev": "node scripts/docker-server.js redeploy dev",
    "docker:logs:dev": "node scripts/docker-server.js logs dev",
    "docker:down": "node scripts/docker-server.js down prod",
    "docker:up": "node scripts/docker-server.js up prod",
    "docker:redeploy": "node scripts/docker-server.js redeploy prod",
    "docker:logs": "node scripts/docker-server.js logs prod"
  }
}
