{
  "name": "app-template-mobile",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "android": "node ../server/scripts/kill-port.js 8081 && set NODE_ENV=development&& set APP_ENV=local&& expo run:android",
    "android:dev": "set NODE_ENV=development&& set APP_ENV=dev&& expo run:android",
    "android:cloud": "set NODE_ENV=production&& set APP_ENV=cloud&& expo run:android",
    "android:build": "node scripts/build-android.js",
    "android:build:dev": "set APP_ENV=dev&& node scripts/build-android.js",
    "android:build:clean": "node scripts/build-android.js --clean",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --config jest.config.js",
    "test:watch": "jest --watch --config jest.config.js"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
